# Copy this file to .env in the same folder and fill in your real values.
# Do not commit your real .env file.

# AI classification, summarisation, chatbot replies, and email draft replies.
GROQ_API_KEY=your_groq_api_key_here

# Mailbox used by Workflow Automation > Email Intake.
# Gmail example:
# IMAP_HOST=imap.gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# IMAP_USERNAME=your_email@gmail.com
# IMAP_PASSWORD=your_gmail_app_password
IMAP_HOST=imap.gmail.com
IMAP_FOLDER=INBOX
IMAP_USERNAME=your_email@example.com
IMAP_PASSWORD=your_email_app_password

# Used when sending manual or automatic replies.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587